{
  "buildCommand": "node inject-env.js",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/entrar",  "destination": "/pintopro-login.html"     },
    { "source": "/app",     "destination": "/pintopro-app.html"       },
    { "source": "/planos",  "destination": "/pintopro-planos.html"    },
    { "source": "/admin",   "destination": "/pintopro-admin.html"     },
    { "source": "/assinar", "destination": "/pintopro-assinar.html"   },
    { "source": "/blog",    "destination": "/blog.html"               },
    { "source": "/sobre",   "destination": "/sobre.html"              },
    { "source": "/termos",  "destination": "/termos.html"             },
    { "source": "/cookies", "destination": "/cookies.html"            }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff"        },
        { "key": "X-Frame-Options",           "value": "DENY"           },
        { "key": "X-XSS-Protection",          "value": "1; mode=block"  },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/pp-config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.+\\.(js|css|png|jpg|jpeg|svg|ico|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
